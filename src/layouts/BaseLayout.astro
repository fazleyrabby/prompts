---
const { title, description } = Astro.props;
import '../styles/global.css';
import Toast from '../components/Toast.astro';
import CommandPalette from '../components/CommandPalette.astro';
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title ? `${title} | Prompt Library` : 'Prompt Library'}</title>
    <meta name="description" content={description || "A minimal, blazing-fast prompt library for developers."} />
    <meta name="keywords" content="prompts, ai, developer prompts, chatgpt library, claude prompts, prompter, fazleyrabbi" />
    <meta name="author" content="fazleyrabbi" />
    <meta name="robots" content="index, follow" />

    <!-- Canonical URL -->
    <link rel="canonical" href={`https://prompts.fazleyrabbi.xyz${Astro.url.pathname}`} />

    <!-- Open Graph / Meta -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://prompts.fazleyrabbi.xyz${Astro.url.pathname}`} />
    <meta property="og:title" content={title ? `${title} | Prompt Library` : 'Prompt Library'} />
    <meta property="og:description" content={description || "A minimal, blazing-fast prompt library for developers."} />
    <meta property="og:site_name" content="Prompt Library" />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={`https://prompts.fazleyrabbi.xyz${Astro.url.pathname}`} />
    <meta property="twitter:title" content={title ? `${title} | Prompt Library` : 'Prompt Library'} />
    <meta property="twitter:description" content={description || "A minimal, blazing-fast prompt library for developers."} />

    <!-- Preconnect to Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link 
      rel="preload" 
      as="style" 
      href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&family=JetBrains+Mono:wght@400;500&display=swap"
    >
    <link 
      href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&family=JetBrains+Mono:wght@400;500&display=swap" 
      rel="stylesheet"
      media="print" 
      onload="this.media='all'"
    >
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    </noscript>
  </head>
  <body class="bg-[var(--bg)] text-[var(--text-primary)] font-body min-h-screen flex flex-col antialiased selection:bg-[var(--accent-start)] selection:text-white pb-6">
    <main class="flex-grow max-w-[1600px] mx-auto w-full px-4 sm:px-6 lg:px-8 pt-6">
      <slot />
    </main>
    <footer class="mt-16 py-10 border-t border-[var(--border)] text-[var(--text-secondary)] font-mono text-xs max-w-[1600px] mx-auto w-full px-6 sm:px-8">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="flex items-center gap-2">
          <p>&copy; {new Date().getFullYear()} Prompt Library</p>
          <span class="opacity-30 hidden md:inline">·</span>
          <p class="hidden md:inline">Made with <span aria-label="love">&hearts;</span> by fazleyrabbi</p>
        </div>
        <div class="flex flex-wrap items-center justify-center gap-y-3 gap-x-6">
          <a href="https://fazleyrabbi.xyz" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--text-primary)] transition-colors font-medium">Portfolio</a>
          <a href="/changelog" class="hover:text-[var(--text-primary)] transition-colors">Changelog</a>
          <a href="https://www.npmjs.com/package/@fazleyrabbi/prompts" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--text-primary)] transition-colors">CLI (NPM)</a>
          <a href="https://github.com/fazleyrabby/prompts.git" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--text-primary)] transition-colors">GitHub</a>
        </div>
      </div>
    </footer>
    <Toast />
    <CommandPalette />
    <script>
      import '../scripts/global.ts';
    </script>
  </body>
</html>

<style is:global>
  :root {
    /* Background */
    --bg: #0B0F14;

    /* Surfaces */
    --surface: #111827;
    --surface-hover: #161B22;

    /* Borders */
    --border: rgba(255, 255, 255, 0.08);
    --border-hover: rgba(255, 255, 255, 0.14);

    /* Text */
    --text-primary: #E5E7EB;
    --text-secondary: #9CA3AF;

    /* Accent */
    --accent-start: #818CF8;
    --accent-end: #A78BFA;
    --accent: linear-gradient(135deg, var(--accent-start), var(--accent-end));
  }

  body {
    background-color: var(--bg);
  }

  /* Scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }
  ::-webkit-scrollbar-track {
    background: var(--bg);
  }
  ::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 4px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: var(--border-hover);
  }
</style>
