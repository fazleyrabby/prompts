---
const { promptText, fullWidth = false } = Astro.props;
---

<button
  type="button"
  class:list={[
    "copy-btn relative inline-flex items-center justify-center rounded-md font-mono text-sm font-medium whitespace-nowrap focus:outline-none focus:ring-2 focus:ring-[var(--accent-start)] focus:ring-offset-2 focus:ring-offset-[var(--bg)] transition-all",
    { "w-full sm:w-auto h-11 px-6": fullWidth },
    { "px-2.5 py-1.5 h-8": !fullWidth }
  ]}
  data-prompt={promptText}
>
  <span class="copy-text whitespace-nowrap">Copy Prompt</span>
  <span class="copied-text absolute inset-0 flex items-center justify-center opacity-0 scale-95 transition-all whitespace-nowrap">Copied ✓</span>
</button>

<style>
  .copy-btn {
    background-color: transparent;
    border: 1px solid var(--border);
    color: var(--text-primary);
    transform-origin: center;
    transition: all 120ms ease-out;
  }

  .copy-btn:hover {
    background-color: var(--surface-hover);
    border-color: var(--border-hover);
  }

  .copy-btn:active {
    transform: scale(0.97);
    transition: transform 80ms ease-out;
  }

  .copy-btn.copied {
    /* Using background from accent-start for copied state */
    background: var(--accent);
    color: white;
    border-color: transparent;
  }

  .copy-btn.copied .copy-text {
    opacity: 0;
    transform: scale(0.95);
  }

  .copy-btn.copied .copied-text {
    opacity: 1;
    transform: scale(1);
    color: white;
  }

  .copy-btn .copy-text {
    transition: opacity 120ms ease-out, transform 120ms ease-out;
  }
</style>

<script>
  function setupCopyButtons() {
    const buttons = document.querySelectorAll('.copy-btn');
    buttons.forEach((btn) => {
      // Remove previous event listener effectively by replacing the node (avoids duplication on astro page transitions)
      const newBtn = btn.cloneNode(true) as HTMLButtonElement;
      if (btn.parentNode) {
        btn.parentNode.replaceChild(newBtn, btn);
      }
      
      newBtn.addEventListener('click', async (e) => {
        e.preventDefault();
        e.stopPropagation(); // prevent clicking link on parent card
        const promptText = newBtn.getAttribute('data-prompt');
        if (!promptText) return;

        try {
          await navigator.clipboard.writeText(promptText);
          newBtn.classList.add('copied');
          setTimeout(() => {
            newBtn.classList.remove('copied');
          }, 2000);
        } catch (err) {
          console.error("Failed to copy", err);
        }
      });
    });
  }

  setupCopyButtons();
  document.addEventListener('astro:page-load', setupCopyButtons);
</script>
