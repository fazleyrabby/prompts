---
const { promptText, slug, label = "Copy Prompt", fullWidth = false } = Astro.props;
---

<button
  type="button"
  class:list={[
    "copy-btn relative inline-flex items-center justify-center rounded-md font-mono text-sm font-medium whitespace-nowrap focus:outline-none focus:ring-2 focus:ring-[var(--accent-start)] focus:ring-offset-2 focus:ring-offset-[var(--bg)] transition-all",
    { "w-full sm:w-auto h-11 px-6": fullWidth },
    { "px-2.5 py-1.5 h-8": !fullWidth }
  ]}
  data-prompt={promptText}
  data-slug={slug}
>
  <span class="copy-text whitespace-nowrap">{label}</span>
  <span class="copied-text absolute inset-0 flex items-center justify-center opacity-0 scale-95 transition-all whitespace-nowrap">Copied ✓</span>
</button>

<style>
  .copy-btn {
    background-color: transparent;
    border: 1px solid var(--border);
    color: var(--text-primary);
    transform-origin: center;
    transition: all 120ms ease-out;
  }

  .copy-btn:hover {
    background-color: var(--surface-hover);
    border-color: var(--border-hover);
  }

  .copy-btn:active {
    transform: scale(0.97);
    transition: transform 80ms ease-out;
  }

  .copy-btn.copied {
    /* Using background from accent-start for copied state */
    background: var(--accent);
    color: white;
    border-color: transparent;
  }

  .copy-btn.copied .copy-text {
    opacity: 0;
    transform: scale(0.95);
  }

  .copy-btn.copied .copied-text {
    opacity: 1;
    transform: scale(1);
    color: white;
  }

  .copy-btn .copy-text {
    transition: opacity 120ms ease-out, transform 120ms ease-out;
  }
</style>

<script>
  function setupCopyDelegation() {
    // Only attach event listener once
    if (document.body.dataset.copyDelegated) return;
    document.body.dataset.copyDelegated = 'true';

    document.body.addEventListener('click', async (e) => {
      const target = e.target as HTMLElement;
      const btn = target.closest('.copy-btn');
      
      if (!btn) return;
      
      e.preventDefault();
      e.stopPropagation(); // prevent clicking link on parent card
      
      const promptText = btn.getAttribute('data-prompt');
      if (!promptText) return;

      try {
        await navigator.clipboard.writeText(promptText);
        
        const promptSlug = btn.getAttribute('data-slug');
        
        // Add copied class to ALL buttons for this prompt (syncs UI across grids)
        const matchingBtns = document.querySelectorAll(`.copy-btn[data-slug="${promptSlug}"]`);
        matchingBtns.forEach(b => b.classList.add('copied'));
        
        // Usage Analytics
        if (promptSlug) {
          const usage = JSON.parse(localStorage.getItem('prompt_usage') || '{}');
          usage[promptSlug] = (usage[promptSlug] || 0) + 1;
          localStorage.setItem('prompt_usage', JSON.stringify(usage));
          
          // Dispatch event so other components can react (e.g. Most Used grid)
          window.dispatchEvent(new Event('prompt_usage_updated'));
        }

        if (typeof (window as any).showToast === 'function') {
          (window as any).showToast('Prompt copied to clipboard!', 'success');
        }
        
        // Re-query in the timeout in case new clones were made (e.g. by Most Used grid)
        setTimeout(() => {
          document.querySelectorAll(`.copy-btn[data-slug="${promptSlug}"]`).forEach(b => {
             b.classList.remove('copied');
          });
        }, 2000);
        
      } catch (err) {
        console.error("Failed to copy", err);
      }
    });
  }

  setupCopyDelegation();
  document.addEventListener('astro:page-load', setupCopyDelegation);
</script>
