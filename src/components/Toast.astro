---
// Toast notification — include this in BaseLayout
---

<div id="toast-container" class="fixed bottom-6 right-6 z-[100] flex flex-col gap-3 pointer-events-none"></div>

<style>
  .toast {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1.25rem;
    border-radius: 12px;
    font-size: 0.8125rem;
    font-weight: 500;
    pointer-events: auto;
    backdrop-filter: blur(16px) saturate(180%);
    box-shadow: 
      0 8px 32px rgba(0,0,0,0.5),
      0 0 0 1px rgba(255,255,255,0.06) inset;
    animation: toastIn 400ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
    font-family: 'DM Sans', sans-serif;
    min-width: 220px;
    cursor: pointer;
    transition: transform 150ms ease, opacity 150ms ease;
  }

  .toast:hover {
    transform: translateX(-4px);
  }

  .toast .toast-icon {
    width: 28px;
    height: 28px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    flex-shrink: 0;
  }

  .toast .toast-body {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .toast .toast-msg {
    color: var(--text-primary);
    font-weight: 500;
    line-height: 1.3;
  }

  .toast .toast-sub {
    font-size: 11px;
    color: var(--text-secondary);
    opacity: 0.7;
  }

  .toast .toast-progress {
    position: absolute;
    bottom: 0;
    left: 12px;
    right: 12px;
    height: 2px;
    border-radius: 1px;
    animation: progress linear forwards;
  }

  .toast.success {
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.12), rgba(6, 78, 59, 0.2));
    border: 1px solid rgba(16, 185, 129, 0.2);
  }
  .toast.success .toast-icon {
    background: rgba(16, 185, 129, 0.2);
    color: #10B981;
  }
  .toast.success .toast-progress {
    background: linear-gradient(90deg, #10B981, transparent);
  }

  .toast.info {
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.12), rgba(49, 46, 129, 0.2));
    border: 1px solid rgba(99, 102, 241, 0.2);
  }
  .toast.info .toast-icon {
    background: rgba(99, 102, 241, 0.2);
    color: #818CF8;
  }
  .toast.info .toast-progress {
    background: linear-gradient(90deg, #818CF8, transparent);
  }

  .toast.warning {
    background: linear-gradient(135deg, rgba(245, 158, 11, 0.12), rgba(120, 53, 15, 0.2));
    border: 1px solid rgba(245, 158, 11, 0.2);
  }
  .toast.warning .toast-icon {
    background: rgba(245, 158, 11, 0.2);
    color: #F59E0B;
  }
  .toast.warning .toast-progress {
    background: linear-gradient(90deg, #F59E0B, transparent);
  }

  .toast.removing {
    animation: toastOut 250ms cubic-bezier(0.5, 0, 0.75, 0) forwards;
  }

  @keyframes toastIn {
    from {
      opacity: 0;
      transform: translateX(60px) scale(0.9);
    }
    to {
      opacity: 1;
      transform: translateX(0) scale(1);
    }
  }

  @keyframes toastOut {
    from {
      opacity: 1;
      transform: translateX(0) scale(1);
    }
    to {
      opacity: 0;
      transform: translateX(40px) scale(0.9);
    }
  }

  @keyframes progress {
    from { width: 100%; }
    to { width: 0%; }
  }
</style>

<script is:inline>
  window.showToast = function(message, type, duration) {
    type = type || 'success';
    duration = duration || 2500;
    var container = document.getElementById('toast-container');
    if (!container) return;

    var icons = {
      success: '✓',
      info: 'ℹ',
      warning: '⚠'
    };

    var toast = document.createElement('div');
    toast.className = 'toast ' + type;
    toast.style.position = 'relative';
    toast.style.overflow = 'hidden';
    toast.innerHTML = 
      '<div class="toast-icon">' + (icons[type] || '✓') + '</div>' +
      '<div class="toast-body">' +
        '<span class="toast-msg">' + message + '</span>' +
      '</div>' +
      '<div class="toast-progress" style="animation-duration: ' + duration + 'ms"></div>';
    
    toast.addEventListener('click', function() {
      toast.classList.add('removing');
      setTimeout(function() { toast.remove(); }, 250);
    });

    container.appendChild(toast);

    setTimeout(function() {
      toast.classList.add('removing');
      setTimeout(function() { toast.remove(); }, 250);
    }, duration);
  };
</script>
