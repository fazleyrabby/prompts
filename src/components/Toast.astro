---
// Toast notification — include this in BaseLayout
---

<div id="toast-container" class="fixed bottom-6 right-6 z-[100] flex flex-col gap-3 pointer-events-none"></div>

<style is:global>
  .toast {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    padding: 1rem 1.25rem;
    border-radius: 14px;
    font-size: 0.875rem;
    pointer-events: auto;
    backdrop-filter: blur(24px) saturate(200%);
    -webkit-backdrop-filter: blur(24px) saturate(200%);
    box-shadow: 
      0 10px 40px -10px rgba(0,0,0,0.5),
      0 0 0 1px rgba(255,255,255,0.08) inset,
      0 1px 0 0 rgba(255,255,255,0.1) inset;
    animation: toastSlideIn 0.4s cubic-bezier(0.2, 0.9, 0.2, 1) forwards;
    font-family: var(--font-body), sans-serif;
    min-width: 280px;
    max-width: 380px;
    cursor: pointer;
    overflow: hidden;
    transition: transform 0.2s cubic-bezier(0.2, 0.9, 0.2, 1), opacity 0.2s ease;
    background: rgba(17, 24, 39, 0.85); /* Dark surface base */
  }

  .toast:hover {
    transform: translateY(-2px) scale(1.01);
  }

  .toast-icon-wrapper {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  .toast svg {
    width: 14px;
    height: 14px;
    stroke-width: 2.5;
  }

  .toast-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex-grow: 1;
  }

  .toast-title {
    color: var(--text-primary);
    font-weight: 600;
    line-height: 1.4;
    letter-spacing: -0.01em;
  }

  .toast-desc {
    color: var(--text-secondary);
    font-size: 0.8125rem;
    line-height: 1.4;
    display: none; /* Hidden by default, shown if text is provided */
  }

  .toast-desc.has-text {
    display: block;
  }

  .toast.success .toast-icon-wrapper {
    background: rgba(16, 185, 129, 0.15);
    color: #34D399;
    box-shadow: 0 0 0 1px rgba(16, 185, 129, 0.2) inset;
  }
  
  .toast.success::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    border-radius: inherit;
    background: radial-gradient(circle at top left, rgba(16, 185, 129, 0.1), transparent 70%);
    pointer-events: none;
  }

  .toast.info .toast-icon-wrapper {
    background: rgba(99, 102, 241, 0.15);
    color: #818CF8;
    box-shadow: 0 0 0 1px rgba(99, 102, 241, 0.2) inset;
  }

  .toast.info::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    border-radius: inherit;
    background: radial-gradient(circle at top left, rgba(99, 102, 241, 0.1), transparent 70%);
    pointer-events: none;
  }

  .toast.warning .toast-icon-wrapper {
    background: rgba(245, 158, 11, 0.15);
    color: #FBBF24;
    box-shadow: 0 0 0 1px rgba(245, 158, 11, 0.2) inset;
  }

  .toast.warning::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    border-radius: inherit;
    background: radial-gradient(circle at top left, rgba(245, 158, 11, 0.1), transparent 70%);
    pointer-events: none;
  }

  .toast-progress-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 3px;
    border-radius: 0 0 14px 14px;
    background: rgba(255,255,255,0.05);
    width: 100%;
    overflow: hidden;
  }

  .toast-progress-fill {
    height: 100%;
    width: 100%;
    transform-origin: left;
    animation: progressFill linear forwards;
  }

  .toast.success .toast-progress-fill { background: #10B981; }
  .toast.info .toast-progress-fill { background: #6366F1; }
  .toast.warning .toast-progress-fill { background: #F59E0B; }

  .toast.removing {
    animation: toastScaleOut 0.3s cubic-bezier(0.5, 0, 0.2, 1) forwards;
  }

  @keyframes toastSlideIn {
    0% {
      opacity: 0;
      transform: translateY(20px) scale(0.95);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes toastScaleOut {
    0% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
    100% {
      opacity: 0;
      transform: translateY(10px) scale(0.95);
    }
  }

  @keyframes progressFill {
    from { transform: scaleX(1); }
    to { transform: scaleX(0); }
  }
</style>

<script is:inline>
  window.showToast = function(message, type, duration, description) {
    type = type || 'success';
    duration = duration || 3000;
    var container = document.getElementById('toast-container');
    if (!container) return;

    var icons = {
      success: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>',
      info: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>',
      warning: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>'
    };

    var toast = document.createElement('div');
    toast.className = 'toast ' + type;
    toast.style.position = 'relative';
    
    var descHtml = description ? '<span class="toast-desc has-text">' + description + '</span>' : '<span class="toast-desc"></span>';

    toast.innerHTML = 
      '<div class="toast-icon-wrapper">' + (icons[type] || icons.success) + '</div>' +
      '<div class="toast-content">' +
        '<span class="toast-title">' + message + '</span>' +
        descHtml +
      '</div>' +
      '<div class="toast-progress-bar"><div class="toast-progress-fill" style="animation-duration: ' + duration + 'ms"></div></div>';
    
    toast.addEventListener('click', function() {
      toast.classList.add('removing');
      setTimeout(function() { toast.remove(); }, 300);
    });

    container.appendChild(toast);

    setTimeout(function() {
      if(!toast.classList.contains('removing')) {
        toast.classList.add('removing');
        setTimeout(function() { toast.remove(); }, 300);
      }
    }, duration);
  };
</script>
