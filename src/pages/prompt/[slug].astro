---
import { getCollection } from 'astro:content';
import { Code } from 'astro:components';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Tag from '../../components/Tag.astro';
import CopyButton from '../../components/CopyButton.astro';
import PromptCard from '../../components/PromptCard.astro';

export async function getStaticPaths() {
  const prompts = await getCollection('prompts');
  return prompts.map(entry => ({
    params: { slug: entry.slug },
    props: { entry, allPrompts: prompts },
  }));
}

const { entry, allPrompts } = Astro.props;
const { Content } = await entry.render();

// Extract the prompt portion for the raw string copying
const rawBody = entry.body;
const parts = rawBody.split('## Notes');
let promptText = parts[0] || '';
const noteText = parts[1] || '';

// Clean the extracted prompt: remove the "## Prompt" heading if it exists
promptText = promptText.replace(/## Prompt\s+/, '').trim();

// Extract variables
const variableRegex = /\{\{([A-Z0-9_]+)\}\}/g;
const matchItr = promptText.matchAll(variableRegex);
const variables = [...new Set(Array.from(matchItr, m => m[1]))];

// Related prompts: same category or overlapping tags, max 4
const relatedPrompts = allPrompts
  .filter(p => p.slug !== entry.slug)
  .map(p => {
    let score = 0;
    if (p.data.category === entry.data.category) score += 3;
    const sharedTags = p.data.tags.filter((t: string) => entry.data.tags.includes(t));
    score += sharedTags.length;
    return { prompt: p, score };
  })
  .filter(r => r.score > 0)
  .sort((a, b) => b.score - a.score)
  .slice(0, 4)
  .map(r => r.prompt);
---

<BaseLayout 
  title={entry.data.title}
  description={entry.data.description}
>
  <div class="max-w-4xl mx-auto">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 text-sm font-mono mb-6 text-[var(--text-secondary)]">
      <a href="/" class="hover:text-[var(--text-primary)] transition-colors">Library</a>
      <span class="opacity-30">/</span>
      <a href={`/?category=${entry.data.category}`} class="capitalize hover:text-[var(--text-primary)] transition-colors">{entry.data.category}</a>
      <span class="opacity-30">/</span>
      <span class="text-[var(--text-primary)] truncate max-w-xs">{entry.data.title}</span>
    </nav>

    <!-- Header -->
    <header class="mb-8">
      <div class="flex items-start justify-between gap-4 mb-4">
        <div>
          <span class="inline-block px-2.5 py-0.5 text-[10px] uppercase tracking-wider font-mono rounded-md bg-[var(--surface)] border border-[var(--border)] text-[var(--text-secondary)] mb-3 capitalize">
            {entry.data.category}
          </span>
          <h1 class="text-3xl sm:text-4xl font-semibold font-heading text-[var(--text-primary)] mb-3 tracking-tight">
            {entry.data.title}
          </h1>
          <p class="text-lg text-[var(--text-secondary)] font-body">
            {entry.data.description}
          </p>
        </div>
        
        <!-- Action Buttons (Desktop) -->
        <div class="relative z-10 hidden sm:flex items-center gap-2 shrink-0 mt-8">
          <button 
            id="shareBtn"
            class="inline-flex items-center gap-1.5 px-2.5 py-1.5 h-8 rounded-md font-mono text-sm font-medium border border-[var(--border)] text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--surface-hover)] transition-all"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
            </svg>
            Share
          </button>
          <CopyButton promptText={promptText} fullWidth={false} />
        </div>
      </div>
      
      <div class="flex flex-wrap items-center gap-2 mt-4">
        {entry.data.tags.map((tag: string) => (
          <Tag label={tag} />
        ))}
        <span class="mx-2 text-[var(--border)]">|</span>
        <span class="model-badge text-xs uppercase font-mono tracking-wider whitespace-nowrap">
          {entry.data.model}
        </span>
      </div>
    </header>

    <div class="h-px bg-[var(--border)] w-full mb-8"></div>

    <!-- Interactive Variables Section -->
    {variables.length > 0 && (
      <div class="mb-8 p-5 bg-[var(--surface)] border border-[var(--border)] rounded-xl relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-[var(--accent-start)]/5 to-transparent pointer-events-none"></div>
        <div class="relative z-10">
          <h3 class="text-sm font-semibold mb-4 flex items-center gap-2 font-heading tracking-tight">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-[var(--accent-start)]" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.533 1.533 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.533 1.533 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd" />
            </svg>
            Customize Variables
          </h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4" id="variable-inputs">
            {variables.map(v => (
              <div>
                <label class="block text-[11px] font-mono uppercase tracking-wider text-[var(--text-secondary)] mb-1.5 pl-1">{v.replace(/_/g, ' ')}</label>
                <input 
                  type="text" 
                  placeholder={`Enter ${v.toLowerCase()}...`}
                  data-var={v}
                  class="variable-input w-full bg-[#0d121c] border border-[var(--border)] rounded-lg px-3.5 py-2.5 text-sm text-[var(--text-primary)] focus:border-[var(--accent-start)] focus:ring-1 focus:ring-[var(--accent-start)]/50 focus:outline-none transition-all placeholder:text-[var(--text-secondary)]/50 font-medium"
                />
              </div>
            ))}
          </div>
        </div>
      </div>
    )}

    <!-- Prompt Section -->
    <section class="mb-10">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-medium font-heading tracking-tight flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[var(--accent-start)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
          </svg>
          Prompt
        </h2>
        <!-- Copy Button (Mobile) -->
        <div class="relative z-10 sm:hidden">
          <CopyButton promptText={promptText} fullWidth={false} />
        </div>
      </div>
      
      <div class="relative group">
        <div class="bg-black rounded-xl overflow-hidden border border-[var(--border)] text-sm shadow-xl font-mono relative code-wrapper">
          <Code code={promptText} lang="markdown" theme="github-dark" wrap={true} />
        </div>
        
        <div class="absolute top-4 right-4 z-20 opacity-0 group-hover:opacity-100 transition-opacity hidden sm:block">
          <CopyButton promptText={promptText} fullWidth={false} />
        </div>
      </div>
    </section>

    <!-- Notes Section -->
    {noteText.trim() && (
      <section class="mb-10 pt-6 border-t border-[var(--border)]">
        <h2 class="text-lg font-medium font-heading tracking-tight flex items-center gap-2 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[var(--accent-end)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Notes
        </h2>
        <div class="prose prose-invert prose-p:text-[var(--text-secondary)] prose-li:text-[var(--text-secondary)] prose-a:text-[var(--accent-start)] font-body markdown-content">
          <Content />
        </div>
      </section>
    )}

    <!-- Related Prompts -->
    {relatedPrompts.length > 0 && (
      <section class="pt-8 border-t border-[var(--border)]">
        <h2 class="text-lg font-medium font-heading tracking-tight flex items-center gap-2 mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[var(--text-secondary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
          </svg>
          Related Prompts
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {relatedPrompts.map((prompt: any) => (
            <PromptCard 
              title={prompt.data.title}
              description={prompt.data.description}
              category={prompt.data.category}
              tags={prompt.data.tags}
              preview={prompt.data.preview}
              model={prompt.data.model}
              slug={prompt.slug}
              promptText={prompt.body.replace(/## Prompt\s+/, '').split('## Notes')[0].trim()}
            />
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .model-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.125rem 0.625rem;
    border-radius: 9999px;
    background-color: rgba(16, 185, 129, 0.12);
    color: #10B981;
    cursor: default;
  }
  
  :global(.code-wrapper pre) {
    background-color: transparent !important;
    padding: 1.5rem !important;
    margin: 0 !important;
    border-radius: 0.75rem;
  }
  
  :global(.code-wrapper code) {
    font-family: var(--font-mono, 'JetBrains Mono', 'IBM Plex Mono', monospace);
    line-height: 1.8;
  }

  /* Hide the original Prompt section from Content, show only Notes */
  .markdown-content :global(h2:first-of-type),
  .markdown-content :global(h2:first-of-type + p),
  .markdown-content :global(h2:first-of-type ~ p:not(h2#notes ~ p)),
  .markdown-content :global(h2:first-of-type ~ ul:not(h2#notes ~ ul)) {
     display: none;
  }
  .markdown-content :global(h2#notes),
  .markdown-content :global(h2#notes ~ *) {
     display: block;
  }
  .markdown-content :global(h2#notes) {
     display: none; /* We already have our own Notes heading */
  }
  .markdown-content :global(ul) { list-style-type: disc; padding-left: 1.5rem; margin-bottom: 1rem; }
  .markdown-content :global(p) { margin-bottom: 1rem; }
</style>

<script>
  const shareBtn = document.getElementById('shareBtn');
  shareBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(window.location.href);
      if (typeof (window as any).showToast === 'function') {
        (window as any).showToast('Link copied to clipboard!', 'success');
      }
    } catch {
      if (typeof (window as any).showToast === 'function') {
        (window as any).showToast('Failed to copy link', 'warning');
      }
    }
  });
</script>

<!-- Interactive Variables Client Script -->
<script define:vars={{ initialPromptText: promptText, variables }}>
  function initInteractiveVars() {
    if (!variables || variables.length === 0) return;
    
    const inputs = document.querySelectorAll('.variable-input');
    const codeBlock = document.querySelector('.code-wrapper code');
    const copyBtns = document.querySelectorAll('.copy-btn');
    
    if (!codeBlock) return;
    
    // We only need to store the HTML once
    if (!window._originalCodeHTML) {
      window._originalCodeHTML = codeBlock.innerHTML;
    }
    const originalHTML = window._originalCodeHTML;
    
    function updatePrompt() {
      let newHTML = originalHTML;
      let newText = initialPromptText;
      
      inputs.forEach(input => {
        const varName = input.getAttribute('data-var');
        if (!varName) return;
        
        const val = input.value;
        const replaceText = val ? val : `{{${varName}}}`;
        
        const regex = new RegExp(`\\{\\{${varName}\\}\\}`, 'g');
        newHTML = newHTML.replace(regex, `<span class="text-[var(--text-primary)] font-semibold bg-[var(--accent-start)]/20 px-1 py-0.5 rounded ring-1 ring-[var(--accent-start)]/30 mx-px">${replaceText}</span>`);
        
        newText = newText.replace(regex, replaceText);
      });
      
      codeBlock.innerHTML = newHTML;
      
      copyBtns.forEach(btn => {
        if (btn.getAttribute('data-original-prompt') === initialPromptText) {
           btn.setAttribute('data-prompt', newText);
        }
      });
    }

    copyBtns.forEach(btn => {
       if (btn.getAttribute('data-prompt') === initialPromptText) {
          btn.setAttribute('data-original-prompt', initialPromptText);
       }
    });
    
    inputs.forEach(input => {
      // Remove old listeners to avoid duplicates if re-init happens
      input.removeEventListener('input', updatePrompt);
      input.addEventListener('input', updatePrompt);
    });
    
    // Trigger once on init to highlight the brackets initially
    updatePrompt();
  }

  initInteractiveVars();
  document.addEventListener('astro:page-load', initInteractiveVars);
</script>
