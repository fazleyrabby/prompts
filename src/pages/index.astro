---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PromptCard from '../components/PromptCard.astro';

// Fetch all prompts
const prompts = await getCollection('prompts');

// Extract unique tags for categories
const allTags = [...new Set(prompts.flatMap(p => p.data.tags || []))].sort();
---

<BaseLayout 
  title="Home" 
  description="A minimal, blazing-fast prompt library for developers."
>
  <!-- Interactive Header with Search -->
  <header class="flex flex-col mb-8 gap-6">
    <div class="flex items-center justify-between border-b border-[var(--border)] pb-4">
      <h1 class="text-2xl font-semibold font-heading tracking-tight text-[var(--text-primary)]">
        Prompt Library
      </h1>
      <span class="text-sm text-[var(--text-secondary)] hidden sm:block">
        {prompts.length} prompts available
      </span>
    </div>

    <div class="flex flex-col gap-4">
      <!-- Search Input -->
      <div class="relative group max-w-2xl">
        <div class="absolute -inset-0.5 bg-gradient-to-r from-[var(--accent-primary)] to-[var(--accent-secondary)] rounded-lg blur opacity-10 group-focus-within:opacity-30 transition duration-500"></div>
        <div class="relative flex items-center bg-[var(--surface-raised)] border border-[var(--border)] rounded-lg px-4 py-2.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-3 text-[var(--text-secondary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input 
            id="searchInput"
            type="text" 
            placeholder="Search by title, tags, or AI model..." 
            class="bg-transparent border-none focus:outline-none w-full text-[var(--text-primary)] placeholder-[var(--text-secondary)] text-sm"
          />
        </div>
      </div>

      <!-- Categories -->
      <div class="flex flex-wrap gap-2 items-center" id="categoryFilters">
        <button 
          data-category="all"
          class="category-btn active px-3 py-1 rounded-md text-xs font-medium border border-[var(--border)] bg-[var(--surface-raised)] hover:bg-[var(--surface-elevated)] transition-all"
        >
          All
        </button>
        {allTags.map(tag => (
          <button 
            data-category={tag}
            class="category-btn px-3 py-1 rounded-md text-xs font-medium border border-[var(--border)] text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:border-[var(--text-secondary)] transition-all"
          >
            {tag}
          </button>
        ))}
      </div>
    </div>
  </header>

  <!-- Grid -->
  <div id="promptGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-5 gap-4">
    {prompts.map((prompt) => (
      <div 
        class="prompt-card-wrapper transition-all duration-300 transform" 
        data-tags={prompt.data.tags.join(',')} 
        data-title={prompt.data.title.toLowerCase()} 
        data-desc={prompt.data.description.toLowerCase()} 
        data-model={prompt.data.model.toLowerCase()}
      >
        <PromptCard 
          title={prompt.data.title}
          description={prompt.data.description}
          category={prompt.data.category}
          tags={prompt.data.tags}
          preview={prompt.data.preview}
          model={prompt.data.model}
          slug={prompt.slug}
          promptText={prompt.body.replace(/## Prompt\s+/, '').split('## Notes')[0].trim()}
        />
      </div>
    ))}
  </div>
  
  <!-- Pagination -->
  <div id="pagination" class="flex items-center justify-center gap-2 mt-12 pb-8">
    <button 
      id="prevPage"
      class="p-2 rounded-md border border-[var(--border)] text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--surface-raised)] disabled:opacity-30 disabled:cursor-not-allowed transition-all"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
      </svg>
    </button>
    <div id="pageNumbers" class="flex items-center gap-2"></div>
    <button 
      id="nextPage"
      class="p-2 rounded-md border border-[var(--border)] text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--surface-raised)] disabled:opacity-30 disabled:cursor-not-allowed transition-all"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
      </svg>
    </button>
  </div>
  
  <div id="noResults" class="hidden text-[var(--text-secondary)] text-center py-20 border border-[var(--border)] border-dashed rounded-lg">
    <p class="mb-2 text-lg">No matches found</p>
    <p class="text-sm">Try using different keywords or categories.</p>
  </div>
</BaseLayout>

<style>
  .category-btn.active {
    @apply border-[var(--accent-primary)] text-[var(--accent-primary)] bg-[var(--accent-primary)]/10;
  }
</style>

<script>
  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  const categoryBtns = document.querySelectorAll('.category-btn');
  const promptCards = document.querySelectorAll('.prompt-card-wrapper');
  const noResults = document.getElementById('noResults');
  const pagination = document.getElementById('pagination');
  const pageNumbers = document.getElementById('pageNumbers');
  const prevBtn = document.getElementById('prevPage') as HTMLButtonElement;
  const nextBtn = document.getElementById('nextPage') as HTMLButtonElement;

  const ITEMS_PER_PAGE = 8;
  let activeCategory = 'all';
  let searchQuery = '';
  let currentPage = 1;
  let filteredCards: HTMLElement[] = [];

  function updatePagination() {
    const totalPages = Math.ceil(filteredCards.length / ITEMS_PER_PAGE);
    
    // Hide pagination if only one page
    if (totalPages <= 1) {
      pagination?.classList.add('hidden');
    } else {
      pagination?.classList.remove('hidden');
    }

    // Update buttons
    prevBtn.disabled = currentPage === 1;
    nextBtn.disabled = currentPage === totalPages;

    // Build page numbers
    if (pageNumbers) {
      pageNumbers.innerHTML = '';
      for (let i = 1; i <= totalPages; i++) {
        const btn = document.createElement('button');
        btn.textContent = i.toString();
        btn.className = `w-8 h-8 rounded-md text-xs font-medium transition-all ${
          i === currentPage 
            ? 'bg-[var(--accent-primary)] text-white' 
            : 'text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--surface-raised)] border border-[var(--border)]'
        }`;
        btn.onclick = () => {
          currentPage = i;
          renderPage();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        };
        pageNumbers.appendChild(btn);
      }
    }
  }

  function renderPage() {
    const startIndex = (currentPage - 1) * ITEMS_PER_PAGE;
    const endIndex = startIndex + ITEMS_PER_PAGE;

    promptCards.forEach(card => (card as HTMLElement).style.display = 'none');

    filteredCards.forEach((card, index) => {
      if (index >= startIndex && index < endIndex) {
        card.style.display = 'block';
        setTimeout(() => {
          card.style.opacity = '1';
          card.style.scale = '1';
        }, 10);
      } else {
        card.style.opacity = '0';
        card.style.scale = '0.95';
      }
    });

    updatePagination();
  }

  function filterPrompts() {
    currentPage = 1; // Reset to page 1 on search/filter
    filteredCards = [];

    promptCards.forEach(card => {
      const htmlCard = card as HTMLElement;
      const tags = htmlCard.dataset.tags?.split(',') || [];
      const title = htmlCard.dataset.title || '';
      const desc = htmlCard.dataset.desc || '';
      const model = htmlCard.dataset.model || '';

      const matchesCategory = activeCategory === 'all' || tags.includes(activeCategory);
      const matchesSearch = title.includes(searchQuery) || 
                            desc.includes(searchQuery) || 
                            model.includes(searchQuery) ||
                            tags.some(tag => tag.toLowerCase().includes(searchQuery));

      if (matchesCategory && matchesSearch) {
        filteredCards.push(htmlCard);
      }
    });

    if (filteredCards.length === 0) {
      noResults?.classList.remove('hidden');
      pagination?.classList.add('hidden');
    } else {
      noResults?.classList.add('hidden');
    }

    renderPage();
  }

  // Event Listeners
  searchInput?.addEventListener('input', (e) => {
    searchQuery = (e.currentTarget as HTMLInputElement).value.toLowerCase();
    filterPrompts();
  });

  categoryBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      categoryBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeCategory = (btn as HTMLElement).dataset.category || 'all';
      filterPrompts();
    });
  });

  prevBtn?.addEventListener('click', () => {
    if (currentPage > 1) {
      currentPage--;
      renderPage();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  });

  nextBtn?.addEventListener('click', () => {
    const totalPages = Math.ceil(filteredCards.length / ITEMS_PER_PAGE);
    if (currentPage < totalPages) {
      currentPage++;
      renderPage();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  });

  // Initial render
  filterPrompts();
</script>
