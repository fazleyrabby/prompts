---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PromptCard from '../components/PromptCard.astro';

// Fetch all prompts
const prompts = await getCollection('prompts');

// Extract unique categories and tags
const allCategories = [...new Set(prompts.map(p => p.data.category))].sort();
const allTags = [...new Set(prompts.flatMap(p => p.data.tags || []))].sort();
---

<BaseLayout 
  title="Home" 
  description="A minimal, blazing-fast prompt library for developers."
>
  <div class="flex gap-6">
    <!-- Sidebar -->
    <aside id="sidebar" class="hidden lg:flex flex-col gap-6 w-64 shrink-0 sticky top-6 self-start lg:max-h-[calc(100vh-4rem)] overflow-y-auto pr-2 bg-[var(--bg)] lg:bg-transparent z-[60]">
      <!-- Mobile Close Button -->
      <div class="lg:hidden flex items-center justify-between mb-4 pb-2 border-b border-[var(--border)]">
        <span class="text-xs font-bold text-[var(--accent-start)] uppercase tracking-widest">Menu</span>
        <button id="closeSidebar" class="p-2 -mr-2 text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors" aria-label="Close menu">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      
      <!-- Search -->
      <div class="relative group">
        <div class="absolute -inset-0.5 bg-gradient-to-r from-[var(--accent-start)] to-[var(--accent-end)] rounded-lg blur opacity-10 group-focus-within:opacity-30 transition duration-500"></div>
        <div class="relative flex items-center bg-[var(--surface)] border border-[var(--border)] rounded-lg px-3 py-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2 text-[var(--text-secondary)] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input 
            id="searchInput"
            type="text" 
            placeholder="Search prompts..." 
            class="bg-transparent border-none focus:outline-none w-full text-[var(--text-primary)] placeholder-[var(--text-secondary)] text-sm"
            aria-label="Search prompts"
          />
          <kbd class="hidden sm:inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-mono text-[var(--text-secondary)] border border-[var(--border)] bg-[var(--bg)] ml-2 shrink-0">
            <span class="os-mod hidden lg:inline">⌘K</span>
            <span class="lg:hidden">/</span>
            <span class="hidden lg:inline opacity-30 mx-1">or</span>
            <span class="hidden lg:inline">/</span>
          </kbd>
        </div>
      </div>

      <!-- Categories -->
      <div>
        <h3 class="text-xs font-semibold text-[var(--text-secondary)] uppercase tracking-wider mb-3">Categories</h3>
        <div class="flex flex-col gap-1" id="categoryFilters">
          <button 
            id="favFilter"
            class="category-btn flex items-center justify-between w-full px-3 py-2 rounded-md text-sm text-left text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--surface-hover)] transition-all mb-1"
          >
            <span class="flex items-center gap-2">
              <svg class="w-3.5 h-3.5 text-rose-400" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
              Favorites
            </span>
            <span id="favCount" class="text-xs font-mono opacity-60">0</span>
          </button>
          <div class="h-px bg-[var(--border)] mb-1"></div>
          <button 
            data-category="all"
            class="category-btn active flex items-center justify-between w-full px-3 py-2 rounded-md text-sm text-left transition-all"
          >
            <span>All Prompts</span>
            <span class="text-xs font-mono opacity-60">{prompts.length}</span>
          </button>
          <div id="categoryContainer" class="flex flex-col gap-1 overflow-hidden transition-all duration-300 max-h-[280px]">
            {allCategories.map(cat => {
              const count = prompts.filter(p => p.data.category === cat).length;
              return (
                <button 
                  data-category={cat}
                  class="category-btn flex items-center justify-between w-full px-3 py-2 rounded-md text-sm text-left text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--surface-hover)] transition-all"
                >
                  <span class="capitalize">{cat}</span>
                  <span class="text-xs font-mono opacity-60">{count}</span>
                </button>
              );
            })}
          </div>
          {allCategories.length > 6 && (
            <button id="toggleCategories" class="text-[11px] font-medium text-[var(--accent-start)] hover:text-[var(--accent-end)] transition-colors mt-2 flex items-center gap-1 group">
              <span class="button-text">Show more</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform group-[.open]:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
          )}
        </div>
      </div>

      <!-- Tags -->
      <div>
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-xs font-semibold text-[var(--text-secondary)] uppercase tracking-wider">Tags</h3>
          <button 
            id="clearTags"
            class="hidden text-[10px] font-medium text-[var(--accent-start)] hover:underline transition-all"
          >
            Clear
          </button>
        </div>
        <div id="tagContainer" class="flex flex-wrap gap-1.5 overflow-hidden transition-all duration-300 max-h-[120px]">
          {allTags.map(tag => (
            <button 
              data-tag={tag}
              class="tag-btn px-2.5 py-1 rounded-full text-[10px] font-medium border border-[var(--border)] text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:border-[var(--border-hover)] transition-all"
            >
              {tag}
            </button>
          ))}
        </div>
        {allTags.length > 12 && (
          <button id="toggleTags" class="text-[11px] font-medium text-[var(--accent-start)] hover:text-[var(--accent-end)] transition-colors mt-3 flex items-center gap-1 group">
            <span class="button-text">Show more</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform group-[.open]:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
        )}
      </div>

      <!-- Sidebar Footer -->
      <div class="mt-auto pt-4 border-t border-[var(--border)]">
        <p class="text-[10px] text-[var(--text-secondary)] font-mono mb-2">
          {prompts.length} prompts &bull; {allCategories.length} categories
        </p>
        <a 
          href="https://www.npmjs.com/package/@fazleyrabbi/prompts" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="flex items-center gap-1.5 text-[10px] text-[var(--text-secondary)] hover:text-[var(--accent-start)] transition-colors font-mono"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          npx @fazleyrabbi/prompts
        </a>
      </div>
    </aside>

    <!-- Main Content -->
    <div class="flex-1 min-w-0">
      <!-- Header Row -->
      <header class="sticky top-0 z-30 bg-[var(--bg)]/80 backdrop-blur-md flex items-center justify-between mb-6 border-b border-[var(--border)] py-4 transition-all">
        <div class="flex items-center gap-3">
          <!-- Mobile Sidebar Toggle -->
          <button id="sidebarToggle" class="lg:hidden p-2 rounded-md border border-[var(--border)] text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--surface)] transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4h13M3 8h9m-9 4h6m4 0l4-4m0 0l4 4m-4-4v12" />
            </svg>
          </button>
          <a href="/" class="group flex items-center gap-3 hover:opacity-80 transition-opacity">
            <h1 class="text-xl sm:text-2xl font-semibold font-heading tracking-tight text-[var(--text-primary)] flex items-center gap-2 group">
              <div class="relative flex items-center justify-center">
                <div class="absolute -inset-1 bg-[var(--accent-start)] blur-md opacity-20 group-hover:opacity-40 transition-opacity duration-500"></div>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 sm:h-6 sm:w-6 text-[var(--accent-start)] relative z-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="4 17 10 11 4 5"></polyline>
                  <line x1="12" y1="19" x2="20" y2="19"></line>
                </svg>
              </div>
              <span class="truncate">Prompt Library</span>
            </h1>
          </a>
        </div>
        <div class="flex items-center gap-3">
          <span id="resultCount" class="text-sm text-[var(--text-secondary)] hidden sm:block">
            {prompts.length} prompts
          </span>

          <div class="relative flex items-center gap-1 px-1.5 py-1 sm:px-2.5 sm:py-1.5 rounded-lg bg-[var(--surface)] border border-[var(--border)] text-[10px] sm:text-[11px] font-medium text-[var(--text-secondary)] hover:border-[var(--border-hover)] hover:bg-[var(--surface-hover)] transition-all cursor-pointer group">
            <span class="hidden sm:inline-block opacity-60 uppercase tracking-tight">Show:</span>
            <span id="pageSizeDisplay" class="text-[var(--text-primary)] font-bold">12</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 sm:h-3.5 sm:w-3.5 opacity-40 group-hover:opacity-100 transition-opacity" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
            <select id="pageSize" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer appearance-none">
              <option value="8">8</option>
              <option value="12">12</option>
              <option value="24">24</option>
              <option value="48">48</option>
              <option value="96">96</option>
            </select>
          </div>

          <button 
            id="openSearchHeader"
            class="hidden sm:flex items-center gap-2 px-3 py-1.5 rounded-lg bg-[var(--surface)] border border-[var(--border)] text-xs font-medium text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:border-[var(--border-hover)] transition-all group"
            aria-label="Open Search"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <span class="hidden md:inline">Search</span>
            <kbd class="hidden lg:inline-flex items-center gap-0.5 px-1.5 py-0.5 rounded text-[10px] font-mono border border-[var(--border)] bg-[var(--bg)] group-hover:border-[var(--text-secondary)]/30 transition-colors">
              <span class="os-mod">⌘</span>K
            </kbd>
          </button>

          <a 
            href="https://github.com/fazleyrabby/prompts.git" 
            target="_blank" 
            rel="noopener noreferrer" 
            class="flex items-center justify-center w-8 h-8 rounded-lg bg-[var(--surface)] border border-[var(--border)] text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:border-[var(--border-hover)] transition-all"
            aria-label="GitHub Repository"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
            </svg>
          </a>

          <a 
            href="https://www.npmjs.com/package/@fazleyrabbi/prompts" 
            target="_blank" 
            rel="noopener noreferrer" 
            class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-[var(--surface)] border border-[var(--border)] text-xs font-medium text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:border-[var(--border-hover)] transition-all"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-[var(--accent-start)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            CLI
          </a>
        </div>
      </header>

      <!-- Active Filters Bar -->
      <div id="activeFilters" class="hidden flex-wrap gap-2 items-center mb-4">
        <span class="text-xs text-[var(--text-secondary)]">Active:</span>
      </div>

      <!-- Top Prompts Section -->
      <div id="topPromptsSection" class="hidden mb-10 pb-10 border-b border-[var(--border)]">
        <h2 class="text-xl font-semibold font-heading tracking-tight flex items-center gap-2 mb-5 text-[var(--text-primary)]">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          Most Used
        </h2>
        <div id="topPromptGrid" class="columns-1 sm:columns-2 xl:columns-3 2xl:columns-4 gap-6">
        </div>
      </div>

      <!-- Grid Title (shown when top prompts exist) -->
      <h2 id="allPromptsHeader" class="hidden text-xl font-semibold font-heading tracking-tight flex items-center gap-2 mb-5 text-[var(--text-primary)]">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[var(--text-secondary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
        </svg>
        Library
      </h2>

      <!-- Grid -->
      <div id="promptGrid" class="columns-1 sm:columns-2 xl:columns-3 2xl:columns-4 gap-6">
        {prompts.map((prompt, index) => (
          <div 
            class="prompt-card-wrapper break-inside-avoid mb-6 transition-all duration-200" 
            style={index >= 12 ? 'display: none;' : ''}
            data-tags={prompt.data.tags.join(',')} 
            data-category={prompt.data.category}
            data-title={prompt.data.title.toLowerCase()} 
            data-desc={prompt.data.description.toLowerCase()} 
            data-model={prompt.data.model.toLowerCase()}
            data-slug={prompt.slug}
          >
            <PromptCard 
              title={prompt.data.title}
              description={prompt.data.description}
              category={prompt.data.category}
              tags={prompt.data.tags}
              preview={prompt.data.preview}
              thumbnail={prompt.data.thumbnail}
              model={prompt.data.model}
              slug={prompt.slug}
              promptText={prompt.body.replace(/## Prompt\s+/, '').split('## Notes')[0].trim()}
              index={index}
            />
          </div>
        ))}
      </div>
      
      <!-- Pagination -->
      <div id="pagination" class="flex items-center justify-center gap-2 mt-10 pb-4">
        <button 
          id="prevPage"
          class="p-2 rounded-md border border-[var(--border)] text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--surface)] disabled:opacity-30 disabled:cursor-not-allowed transition-all"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
        </button>
        <div id="pageNumbers" class="flex items-center gap-1"></div>
        <button 
          id="nextPage"
          class="p-2 rounded-md border border-[var(--border)] text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--surface)] disabled:opacity-30 disabled:cursor-not-allowed transition-all"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
          </svg>
        </button>
      </div>

      <!-- No Results -->
      <div id="noResults" class="hidden text-[var(--text-secondary)] text-center py-20 border border-[var(--border)] border-dashed rounded-lg">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 mx-auto mb-3 opacity-20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <p class="mb-2 text-lg">No matches found</p>
        <p class="text-sm">Try using different keywords or categories.</p>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .category-btn.active {
    background-color: var(--surface);
    color: var(--text-primary);
    border-left: 2px solid var(--accent-start);
  }

  .tag-btn.active {
    border-color: var(--accent-start);
    color: var(--accent-start);
    background-color: color-mix(in srgb, var(--accent-start) 12%, transparent);
  }

  /* Mobile sidebar overlay */
  #sidebar.mobile-open {
    display: flex !important;
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    z-index: 100; /* Higher than header and overlay */
    width: 280px;
    height: 100dvh;
    max-height: 100dvh;
    padding: 1.5rem;
    background-color: var(--bg);
    border-right: 1px solid var(--border);
    animation: slideIn 200ms cubic-bezier(0.16, 1, 0.3, 1);
    overflow-y: auto;
    box-shadow: 20px 0 50px rgba(0, 0, 0, 0.5);
  }

  #sidebar-overlay {
    display: none;
  }
  #sidebar-overlay.active {
    display: block;
    position: fixed;
    inset: 0;
    z-index: 90; /* Just below sidebar */
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(4px);
  }

  @keyframes slideIn {
    from { transform: translateX(-100%); }
    to { transform: translateX(0); }
  }

  /* Custom scrollbar for sidebar */
  #sidebar::-webkit-scrollbar {
    width: 4px;
  }
  #sidebar::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 2px;
  }
</style>

<script>
  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  const categoryBtns = document.querySelectorAll('.category-btn');
  const tagBtns = document.querySelectorAll('.tag-btn');
  const promptCards = document.querySelectorAll('.prompt-card-wrapper');
  const noResults = document.getElementById('noResults');
  const pagination = document.getElementById('pagination');
  const pageNumbers = document.getElementById('pageNumbers');
  const prevBtn = document.getElementById('prevPage') as HTMLButtonElement;
  const nextBtn = document.getElementById('nextPage') as HTMLButtonElement;
  const resultCount = document.getElementById('resultCount');
  const sidebar = document.getElementById('sidebar');
  const sidebarToggle = document.getElementById('sidebarToggle');
  const clearTagsBtn = document.getElementById('clearTags');
  const favFilterBtn = document.getElementById('favFilter');
  const favCountEl = document.getElementById('favCount');

  const pageSizeSelect = document.getElementById('pageSize') as HTMLSelectElement;
  const pageSizeDisplay = document.getElementById('pageSizeDisplay');
  let ITEMS_PER_PAGE = parseInt(localStorage.getItem('prompt_library_page_size') || '12');
  
  if (pageSizeSelect) {
    pageSizeSelect.value = ITEMS_PER_PAGE.toString();
    if (pageSizeDisplay) pageSizeDisplay.textContent = ITEMS_PER_PAGE.toString();
    
    pageSizeSelect.addEventListener('change', (e) => {
      ITEMS_PER_PAGE = parseInt((e.target as HTMLSelectElement).value);
      if (pageSizeDisplay) pageSizeDisplay.textContent = ITEMS_PER_PAGE.toString();
      localStorage.setItem('prompt_library_page_size', ITEMS_PER_PAGE.toString());
      currentPage = 1;
      filterPrompts();
    });
  }

  let activeCategory = 'all';
  let activeTags: string[] = [];
  let searchQuery = '';
  let currentPage = 1;
  let filteredCards: HTMLElement[] = [];
  let showFavoritesOnly = false;

  function updateFavCount() {
    const favs: string[] = JSON.parse(localStorage.getItem('prompt-favorites') || '[]');
    if (favCountEl) favCountEl.textContent = favs.length.toString();
  }
  updateFavCount();
  window.addEventListener('favorites-changed', () => {
    updateFavCount();
    if (showFavoritesOnly) filterPrompts();
  });

  // Mobile sidebar initialization
  function initMobileSidebar() {
    const sidebar = document.getElementById('sidebar');
    const sidebarToggle = document.getElementById('sidebarToggle');
    const closeSidebar = document.getElementById('closeSidebar');
    
    if (!sidebar || !sidebarToggle || sidebarToggle.getAttribute('data-sidebar-init')) return;
    sidebarToggle.setAttribute('data-sidebar-init', 'true');

    // Check if idempotent (avoid duplicate overlays)
    let overlay = document.getElementById('sidebar-overlay');
    if (!overlay) {
      overlay = document.createElement('div');
      overlay.id = 'sidebar-overlay';
      document.body.appendChild(overlay);
    }

    const closeSidebarFn = () => {
      sidebar?.classList.remove('mobile-open');
      overlay?.classList.remove('active');
      document.body.style.overflow = '';
    };

    const toggleSidebarFn = () => {
      const isOpen = sidebar?.classList.contains('mobile-open');
      if (isOpen) {
        closeSidebarFn();
      } else {
        sidebar?.classList.add('mobile-open');
        overlay?.classList.add('active');
        document.body.style.overflow = 'hidden';
      }
    };

    sidebarToggle.addEventListener('click', toggleSidebarFn);
    closeSidebar?.addEventListener('click', closeSidebarFn);
    overlay.addEventListener('click', closeSidebarFn);
  }

  initMobileSidebar();
  document.addEventListener('astro:page-load', initMobileSidebar);

  // Collapsible sections
  const toggleCategoriesBtn = document.getElementById('toggleCategories');
  const categoryContainer = document.getElementById('categoryContainer');
  
  toggleCategoriesBtn?.addEventListener('click', () => {
    const isOpen = categoryContainer?.style.maxHeight === 'none';
    if (isOpen) {
      if (categoryContainer) categoryContainer.style.maxHeight = '280px';
      toggleCategoriesBtn.classList.remove('open');
      const text = toggleCategoriesBtn.querySelector('.button-text');
      if (text) text.textContent = 'Show more';
    } else {
      if (categoryContainer) categoryContainer.style.maxHeight = 'none';
      toggleCategoriesBtn.classList.add('open');
      const text = toggleCategoriesBtn.querySelector('.button-text');
      if (text) text.textContent = 'Show less';
    }
  });

  const toggleTagsBtn = document.getElementById('toggleTags');
  const tagContainer = document.getElementById('tagContainer');

  toggleTagsBtn?.addEventListener('click', () => {
    const isOpen = tagContainer?.style.maxHeight === 'none';
    if (isOpen) {
      if (tagContainer) tagContainer.style.maxHeight = '120px';
      toggleTagsBtn.classList.remove('open');
      const text = toggleTagsBtn.querySelector('.button-text');
      if (text) text.textContent = 'Show more';
    } else {
      if (tagContainer) tagContainer.style.maxHeight = 'none';
      toggleTagsBtn.classList.add('open');
      const text = toggleTagsBtn.querySelector('.button-text');
      if (text) text.textContent = 'Show less';
    }
  });

  function updatePagination() {
    const totalPages = Math.ceil(filteredCards.length / ITEMS_PER_PAGE);
    
    if (totalPages <= 1) {
      pagination?.classList.add('hidden');
    } else {
      pagination?.classList.remove('hidden');
    }

    if (prevBtn) prevBtn.disabled = currentPage === 1;
    if (nextBtn) nextBtn.disabled = currentPage === totalPages;

    if (pageNumbers) {
      pageNumbers.innerHTML = '';
      for (let i = 1; i <= totalPages; i++) {
        const btn = document.createElement('button');
        btn.textContent = i.toString();
        const isActive = i === currentPage;
        btn.style.cssText = `
          width: 32px; height: 32px; border-radius: 6px; 
          font-size: 12px; font-weight: 500; transition: all 150ms;
          ${isActive 
            ? 'background: var(--accent-start); color: white;' 
            : 'color: var(--text-secondary); border: 1px solid var(--border);'}
        `;
        btn.onmouseenter = () => { if (!isActive) btn.style.background = 'var(--surface)'; };
        btn.onmouseleave = () => { if (!isActive) btn.style.background = 'transparent'; };
        btn.onclick = () => {
          currentPage = i;
          renderPage();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        };
        pageNumbers.appendChild(btn);
      }
     }
  }

  function renderPage() {
    requestAnimationFrame(() => {
      const startIndex = (currentPage - 1) * ITEMS_PER_PAGE;
      const endIndex = startIndex + ITEMS_PER_PAGE;

      promptCards.forEach(card => {
        const el = card as HTMLElement;
        el.style.display = 'none';
      });

      filteredCards.forEach((card, index) => {
        if (index >= startIndex && index < endIndex) {
          card.style.display = 'block';
        }
      });

      // Update result count
      if (resultCount) {
        resultCount.textContent = `${filteredCards.length} prompt${filteredCards.length !== 1 ? 's' : ''}`;
      }

      updatePagination();
    });
  }

  function filterPrompts() {
    currentPage = 1;
    filteredCards = [];

    promptCards.forEach(card => {
      const el = card as HTMLElement;
      const tags = el.dataset.tags?.split(',') || [];
      const category = el.dataset.category || '';
      const title = el.dataset.title || '';
      const desc = el.dataset.desc || '';
      const model = el.dataset.model || '';

      const matchesCategory = activeCategory === 'all' || category === activeCategory;
      const matchesTags = activeTags.length === 0 || activeTags.some(t => tags.includes(t));
      const matchesSearch = searchQuery === '' ||
                            title.includes(searchQuery) || 
                            desc.includes(searchQuery) || 
                            model.includes(searchQuery) ||
                            tags.some(tag => tag.toLowerCase().includes(searchQuery));
      
      // Favorites filter
      let matchesFav = true;
      if (showFavoritesOnly) {
        const favs: string[] = JSON.parse(localStorage.getItem('prompt-favorites') || '[]');
        matchesFav = favs.includes(el.dataset.slug || '');
      }

      if (matchesCategory && matchesTags && matchesSearch && matchesFav) {
        filteredCards.push(el);
      }
    });

    if (filteredCards.length === 0) {
      noResults?.classList.remove('hidden');
      pagination?.classList.add('hidden');
    } else {
      noResults?.classList.add('hidden');
    }

    renderPage();
    updateTopPrompts();
  }

  function updateTopPrompts() {
    const topSection = document.getElementById('topPromptsSection');
    const libHeader = document.getElementById('allPromptsHeader');
    const topGrid = document.getElementById('topPromptGrid');
    
    // Check if defaults are active
    const isFiltered = activeCategory !== 'all' || activeTags.length > 0 || searchQuery !== '' || showFavoritesOnly;
    
    // Parse usage
    const usage = JSON.parse(localStorage.getItem('prompt_usage') || '{}');
    const sortedUsage = Object.entries(usage)
      .sort((a, b) => (b[1] as number) - (a[1] as number))
      .filter(([slug, count]) => (count as number) > 0);

    if (isFiltered || sortedUsage.length === 0) {
      if (topSection) topSection.classList.add('hidden');
      if (libHeader) libHeader.classList.add('hidden');
      if (topGrid) topGrid.innerHTML = '';
      return;
    }

    if (topSection) topSection.classList.remove('hidden');
    if (libHeader) libHeader.classList.remove('hidden');
    if (topGrid) {
      topGrid.innerHTML = '';
      const topSlugs = sortedUsage.slice(0, 4).map(s => s[0]);
      
      const promptGrid = document.getElementById('promptGrid');
      if (promptGrid) {
         topSlugs.forEach(slug => {
            const card = promptGrid.querySelector(`[data-slug="${slug}"]`);
            if (card) {
               const cloned = card.cloneNode(true) as HTMLElement;
               cloned.style.display = 'block'; // force visible
               topGrid.appendChild(cloned);
            }
         });
         
         // Re-bind listeners for the newly cloned buttons
         setTimeout(() => {
           document.dispatchEvent(new Event('astro:page-load'));
         }, 50);
      }
    }
  }

  // Search debounce
  let searchTimeout: any;
  searchInput?.addEventListener('input', (e) => {
    searchQuery = (e.currentTarget as HTMLInputElement).value.toLowerCase();
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
      filterPrompts();
    }, 150);
  });

  // Category buttons
  categoryBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      categoryBtns.forEach(b => b.classList.remove('active'));
      favFilterBtn?.classList.remove('active');
      btn.classList.add('active');
      activeCategory = (btn as HTMLElement).dataset.category || 'all';
      showFavoritesOnly = false;
      filterPrompts();
    });
  });

  // Favorites filter
  favFilterBtn?.addEventListener('click', () => {
    categoryBtns.forEach(b => b.classList.remove('active'));
    favFilterBtn.classList.add('active');
    showFavoritesOnly = true;
    activeCategory = 'all';
    filterPrompts();
  });

  // Tag buttons (toggle)
  function updateClearBtn() {
    if (activeTags.length > 0) {
      clearTagsBtn?.classList.remove('hidden');
    } else {
      clearTagsBtn?.classList.add('hidden');
    }
  }

  tagBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = (btn as HTMLElement).dataset.tag || '';
      btn.classList.toggle('active');
      
      if (activeTags.includes(tag)) {
        activeTags = activeTags.filter(t => t !== tag);
      } else {
        activeTags.push(tag);
      }
      updateClearBtn();
      filterPrompts();
    });
  });

  // Clear all tags
  clearTagsBtn?.addEventListener('click', () => {
    activeTags = [];
    tagBtns.forEach(btn => btn.classList.remove('active'));
    updateClearBtn();
    filterPrompts();
  });

  // Pagination
  prevBtn?.addEventListener('click', () => {
    if (currentPage > 1) {
      currentPage--;
      renderPage();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  });

  nextBtn?.addEventListener('click', () => {
    const totalPages = Math.ceil(filteredCards.length / ITEMS_PER_PAGE);
    if (currentPage < totalPages) {
      currentPage++;
      renderPage();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  });

  // Initial render — check URL for ?category= param
  const urlParams = new URLSearchParams(window.location.search);
  const urlCategory = urlParams.get('category');
  
  if (urlCategory) {
    // Find and activate the matching category button
    categoryBtns.forEach(btn => {
      const cat = (btn as HTMLElement).dataset.category || '';
      if (cat === urlCategory) {
        categoryBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeCategory = cat;
      }
    });
  }

  filterPrompts();

  // Keyboard shortcuts
  document.addEventListener('keydown', (e) => {
    const target = e.target as HTMLElement;
    const isInput = target.tagName === 'INPUT' || target.tagName === 'TEXTAREA';

    // "/" to focus search (when not typing)
    if (e.key === '/' && !isInput) {
      e.preventDefault();
      searchInput?.focus();
    }

    // Escape to clear search and reset
    if (e.key === 'Escape') {
      if (searchInput && searchInput.value) {
        searchInput.value = '';
        searchQuery = '';
        filterPrompts();
      }
      searchInput?.blur();
    }

    // Left/Right arrows for pagination (when not typing)
    if (!isInput) {
      if (e.key === 'ArrowLeft' && currentPage > 1) {
        currentPage--;
        renderPage();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
      if (e.key === 'ArrowRight') {
        const totalPages = Math.ceil(filteredCards.length / ITEMS_PER_PAGE);
        if (currentPage < totalPages) {
          currentPage++;
          renderPage();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      }
    }
  });

  // OS modifier detection (⌘ for Mac, Ctrl for others)
  const osModElements = document.querySelectorAll('.os-mod');
  const isMac = navigator.platform.toUpperCase().indexOf('MAC') >= 0 || navigator.userAgent.toUpperCase().indexOf('MAC') >= 0;
  
  osModElements.forEach(el => {
    // If it's a dedicated modifier span like in the header
    if (el.textContent === '⌘') {
      if (!isMac) el.textContent = 'Ctrl';
    } 
    // If it's the combined string like in the sidebar
    else if (el.textContent === '⌘K') {
      if (!isMac) el.textContent = 'Ctrl K';
    }
  });

  // Open Command Palette from header button
  const openSearchHeader = document.getElementById('openSearchHeader');
  openSearchHeader?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('open-command-palette'));
  });

  // Re-render top prompts when usage analytics update across components
  window.addEventListener('prompt_usage_updated', () => {
    updateTopPrompts();
  });
</script>
